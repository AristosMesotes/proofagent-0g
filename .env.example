# proofagent-0g -- env template. Copy to .env (gitignored) and fill with YOUR values.
# Use a FRESH demo wallet, never a shared/product key. NEVER commit .env.
OG_RPC=                    # 0G Aristotle JSON-RPC URL
ZEROG_RPC_URL=             # 0G RPC (alternate / indexer)
CHAIN_ID=16661             # 0G Aristotle
TESTNET_CHAIN_ID=16602     # Galileo testnet
WALLET_ADDRESS=            # your fresh demo wallet address (0x...)
PRIVATE_KEY=               # your fresh demo wallet private key -- NEVER commit
MANDATE_REGISTRY_ADDRESS=  # deployed MandateRegistry on 0G (confirm/deploy first)
PER_TX_CAP_USD=2

# --- STEP DEPTH-BRAIN -- the 0G Compute TEE attestation (design §9 Depth). The DEFAULT offline build keeps
#     the brain stamp PENDING; the LIVE attestation is OPERATOR-GATED and needs a FUNDED 0G Compute
#     sub-account + a TEE/TeeML provider. Leave these blank to keep the brain PENDING (the honest default).
#     The agent calls the PUBLIC @0glabs/0g-serving-broker SDK directly (no bridge); attested=true ONLY when
#     a real service attestation AND a real per-response enclave signature both verify -- never the model's word.
BRAIN_LIVE=                 # set to 1 to ENABLE the operator-gated live attestation path (default: off => PENDING)
OG_COMPUTE_PROVIDER=        # the 0G Compute TEE serving-provider address (0x...) to attest + infer against
OG_COMPUTE_RPC_URL=         # the 0G JSON-RPC the broker wallet uses (defaults to OG_RPC if unset)
OG_COMPUTE_WALLET_KEY=      # the FUNDED 0G Compute sub-account broker wallet key -- NEVER commit (gitignored .env only)
OG_COMPUTE_MODEL=           # the wire model id to request (e.g. an org-prefixed public 0G Compute model)
OG_COMPUTE_ATTEST_DIR=      # a scratch directory the SDK writes the attestation report into
OG_COMPUTE_ATTEST_TTL_MS=3600000   # re-attest a provider's service attestation after this many ms (default 1h)

# --- HOSTED-LLM BRAIN -- the agent's REASONING on a configurable hosted model (design SS7 "Brain is a hosted
#     LLM at this stage, honestly labelled"). This is the agent's planner -- a CLAIM the on-chain verifier
#     checks; it is NOT the 0G Compute TEE attestation above (a hosted reply proves nothing about WHICH model
#     ran). A plan it produces carries brain="hosted-llm", never "tee". OPT-IN: set BOTH a key and a model, or
#     leave blank to keep the deterministic offline stub (the honest default; no network). Point BRAIN_BASE_URL
#     at ANY OpenAI-compatible /chat/completions host (the OpenRouter public endpoint, a self-hosted vLLM, ...).
OPENROUTER_API_KEY=         # the bearer key for the hosted LLM (gitignored .env ONLY -- never commit/log)
BRAIN=                      # the wire model id to request (e.g. an OpenRouter model slug, or a served model path)
BRAIN_BASE_URL=             # the OpenAI-compatible base URL (default: https://openrouter.ai/api/v1 if unset)

# --- STEP WOW-SWAP -- the swap leg (Oku/Uniswap-V3, design WOW Feature 1). MAINNET-only on 0G (no 16602
#     deployment) -> the live swap moves REAL value and is OPERATOR-GATED. See demo/EVIDENCE_SWAP.md.
OG_RPC_MAINNET=            # 0G Aristotle (16661) JSON-RPC URL -- the swap venue (mainnet)
SWAP_ROUTER02=0x807F4E281B7A3B324825C64ca53c69F0b418dE40   # Oku SwapRouter02 (public)
QUOTER_V2=0xaa52bB8110fE38D0d2d2AF0B85C3A3eE622CA455        # Oku QuoterV2 (public)
SWAP_TOKEN_IN=             # the asset to SELL (mandate-allowlisted; e.g. USDC.e / W0G)
SWAP_TOKEN_OUT=            # the asset to BUY
SWAP_FEE_TIER=10000        # the V3 pool fee tier (1%; fallback 3000)
SWAP_AMOUNT_IN=            # exact input in tokenIn MINOR units (bounded by the per-trade cap)
SWAP_SLIPPAGE_BPS=50       # slippage tolerance in bps (50 = 0.5%); floor = expectedOut*(1 - bps/10000)

# --- STEP WOW-BRIDGE -- the bridge legs (Chainlink CCIP, design WOW Feature 3 / 3b). CCIP on 0G is
#     MAINNET-only -> Galileo (16602) CCIP is DECOMMISSIONED, no testnet rehearsal -> the live bridge moves
#     REAL value and is OPERATOR-GATED. The DESTINATION leg lives on the OTHER chain, so the verifier needs
#     BOTH a 0G RPC and the destination chain's RPC to read both legs. See demo/EVIDENCE_BRIDGE.md.
CCIP_ROUTER=0x0aA145a62153190B8f0D3cA00c441e451529f755          # the public 0G CCIP Router (ccipSend)
BRIDGE_DEST_SELECTOR=      # the EXPECTED CCIP destination selector (uint64) -- must be an allow-listed lane
BRIDGE_TOKEN=             # the bridged asset (USDC.E 0x1f3AA82227281cA364bFb3d253B0f1af1Da6473E / W0G ...)
BRIDGE_TOKEN_POOL=        # the burnMint / lockRelease pool to approve before ccipSend (per-lane; from config)
BRIDGE_RECEIVER=          # the receiver on the destination chain (your fresh demo wallet)
BRIDGE_AMOUNT=           # exact amount sent into CCIP, MINOR units (bounded by the per-trade cap)
BRIDGE_TOLERANCE_BPS=50    # release tolerance in bps (CCIP fee allowance); minRelease = amount*(1 - bps/10000)
BRIDGE_FEE_TOKEN=0x0000000000000000000000000000000000000000   # CCIP fee token (address(0) = native gas / msg.value)
# The DESTINATION chain RPC the verifier reads the release/mint leg on (the OTHER chain of the hop):
DEST_RPC=                 # e.g. an Ethereum / Arbitrum / Base / BNB mainnet JSON-RPC URL (for the dest leg)
